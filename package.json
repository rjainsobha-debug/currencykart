{
  "name": "currencykart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel:build": "npm run prisma:generate && npm run build",
    "prestart": "npm run env:validate",
    "start": "next start",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "env:validate": "tsx scripts/validate-env.ts",
    "workflow:validate": "tsx scripts/validate-workflow.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "security:audit": "npm audit",
    "env:production": "tsx scripts/validate-production-env.ts",
    "seo:validate": "tsx scripts/validate-seo.ts",
    "prelaunch:check": "npm run env:production && npm run seo:validate && tsx scripts/check-release-content.ts",
    "qa:preflight": "npm run env:validate && npm run prisma:generate && npm run workflow:validate && npm run build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "latest",
    "@aws-sdk/client-s3": "^3.821.0",
    "@aws-sdk/client-sesv2": "^3.821.0",
    "@aws-sdk/s3-request-presigner": "^3.821.0",
    "@hookform/resolvers": "latest",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "next-auth": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "latest",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/bcryptjs": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "prisma": "^6.19.0",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
